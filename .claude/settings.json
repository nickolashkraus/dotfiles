{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Edit",
      "Glob",
      "Grep",
      "LSP",
      "Read",
      "WebFetch",
      "WebSearch"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": []
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-compact-log.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "spinnerTipsEnabled": false,
  "syntaxHighlightingDisabled": false,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi",
  "editorMode": "vim"
}
