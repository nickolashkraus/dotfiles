<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <!-- Runs `system-update` daily at 08:00. -->
  <dict>
    <key>Label</key>
    <string>io.nickolaskraus.system-update</string>
    <!--
      launchd does not expand environment variables in plist values, so an
      absolute path here would pin this file to a single machine. It does set
      HOME for a gui/<uid> agent, so the job runs via `sh -c` and lets the
      shell expand $HOME. The redirect stands in for StandardOutPath and
      StandardErrorPath, which are subject to the same no-expansion rule.
      `exec` replaces the shell, so ProcessType and LowPriorityIO still apply
      to system-update itself. `install` creates the log directory; the
      redirect fails if it does not exist.

      Nothing else prunes the log, so it is rotated here, before the redirect
      opens it. Rotating afterwards would not work: the redirect holds the
      inode open, so a renamed file would keep receiving the run's output.
      One generation is kept, which is enough to compare a failed run against
      the last good one.
      -->
    <key>ProgramArguments</key>
    <array>
      <string>/bin/sh</string>
      <string>-c</string>
      <string>log="$HOME/.local/state/system-update.log"; install -d "${log%/*}"; [ "$(stat -f%z "$log" 2&gt;/dev/null || echo 0)" -gt 1048576 ] &amp;&amp; mv -f "$log" "$log.1"; exec "$HOME/bin/system-update" &gt;&gt; "$log" 2&gt;&amp;1</string>
    </array>
    <!--
      `system-update` runs `dotfiles install`, and that script reloads this
      agent. Booting out a job kills its process tree, so an unguarded reload
      would terminate the very run that triggered it, and every step below the
      reload would be skipped. This marker is inherited by the whole tree and
      lets `install` recognize that it is running under this agent and leave
      the reload alone.
      -->
    <key>EnvironmentVariables</key>
    <dict>
      <key>SYSTEM_UPDATE_AGENT</key>
      <string>1</string>
    </dict>
    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>8</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>
    <key>ProcessType</key>
    <string>Background</string>
    <key>LowPriorityIO</key>
    <true/>
  </dict>
</plist>
